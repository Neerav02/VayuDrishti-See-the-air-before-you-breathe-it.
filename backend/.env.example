# VayuDrishti Environment Variables
# Copy this to .env and fill in your keys

# Groq API Key (free: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAQ API Key (free, optional: https://openaq.org)
# If not set, the system works fine with Open-Meteo only
OPENAQ_API_KEY=

# Debug mode
DEBUG=true
